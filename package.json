{
	"name": "obsidian-kanban-base",
	"version": "1.0.4",
	"description": "A Kanban base view based on folders",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:e2e": "wdio run ./wdio.conf.mts",
		"e2e:dev": "E2E_DEV=1 wdio run ./wdio.conf.mts",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@chromatic-com/storybook": "^5.0.1",
		"@eslint/js": "9.30.1",
		"@preact/preset-vite": "^2.10.1",
		"@storybook/addon-a11y": "^10.2.15",
		"@storybook/addon-docs": "^10.2.15",
		"@storybook/addon-vitest": "^10.2.15",
		"@storybook/preact-vite": "^10.2.15",
		"@testing-library/preact": "^3.2.4",
		"@types/mocha": "^10.0.10",
		"@types/node": "^22.19.15",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18",
		"@vitest/ui": "^4.0.18",
		"@wdio/cli": "^9.29.1",
		"@wdio/local-runner": "^9.29.1",
		"@wdio/mocha-framework": "^9.29.1",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"eslint-plugin-storybook": "^10.2.15",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^28.1.0",
		"mocha": "^11.7.6",
		"playwright": "^1.58.2",
		"prettier": "^3.8.1",
		"prettier-plugin-organize-imports": "^4.3.0",
		"storybook": "^10.2.15",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.0.18",
		"wdio-obsidian-reporter": "^3.1.1",
		"wdio-obsidian-service": "^3.1.1"
	},
	"dependencies": {
		"@preact/signals": "^2.8.2",
		"obsidian": "latest",
		"preact": "^10.26.9",
		"unicode-emoji-json": "^0.8.0",
		"xstate": "^5.28.0"
	}
}
